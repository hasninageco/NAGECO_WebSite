{
  "name": "nageco-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:standalone": "next build",
    "build:cpanel": "node scripts/build-cpanel.mjs",
    "package:standalone": "node scripts/package-standalone.mjs",
    "artifact": "npm run build:standalone && npm run package:standalone",
    "artifact:cpanel": "npm run build:cpanel && npm run package:standalone",
    "start": "node server.js",
    "start:next": "next start",
    "start:artifact": "node dist-standalone/server.js",
    "lint": "next lint",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:push": "prisma db push --schema prisma/schema.prisma && prisma generate --schema prisma/schema.prisma",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:sync-no-users": "node scripts/sync-data-no-users.mjs",
    "db:sync-with-users": "node scripts/sync-data-with-users.mjs"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/leaflet": "^1.9.21",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "next": "^15.1.0",
    "next-auth": "^4.24.10",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-simple-maps": "^3.0.0",
    "sanitize-html": "^2.13.1",
    "sonner": "^1.7.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.13",
    "@types/react-dom": "^18.3.1",
    "@types/sanitize-html": "^2.13.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
